{
  "name": "poisonedfinance-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll=false"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "expo": "~54.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "react": "19.2.7",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "babel-preset-expo": "~54.0.11",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.0",
    "react-test-renderer": "19.2.7",
    "jest": "^29.7.0",
    "jest-cucumber": "^4.5.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.3.3"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "react-test-renderer": "19.2.7"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testMatch": [
      "**/?(*.)+(spec|test).[jt]s?(x)",
      "**/__tests__/**/*.steps.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|jest-cucumber|@cucumber|uuid)"
    ]
  }
}
